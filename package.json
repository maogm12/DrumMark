{
  "name": "drummark",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "npm run build-docs",
    "dev": "vite --host",
    "build": "tsc -b && npm run build-docs && vite build && npm run bundle:report",
    "build-docs": "tsx build-docs.ts",
    "bundle:report": "node scripts/report_bundle.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "drummark": "tsx src/cli.ts"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/lint": "^6.9.5",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.1",
    "@lezer/highlight": "^1.2.3",
    "opensheetmusicdisplay": "^1.9.7",
    "react": "^19.2.0",
    "react-dom": "^19.0.0",
    "vexflow": "^5.0.0"
  },
  "devDependencies": {
    "@lezer/generator": "^1.8.0",
    "@lezer/lr": "^1.4.10",
    "@lezer/markdown": "^1.6.3",
    "@types/jsdom": "^28.0.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "canvas": "^3.2.3",
    "jsdom": "^29.0.2",
    "playwright": "^1.59.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.1.11",
    "vitest": "^3.2.4"
  }
}
